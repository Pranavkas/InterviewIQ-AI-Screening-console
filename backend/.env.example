# --- Database ---
DATABASE_URL=sqlite:///./data/interview.db

# --- LLM Provider ---
# "ollama" = fully local, no API key needed (default)
# "groq"   = hosted, fast inference — needs GROQ_API_KEY
LLM_PROVIDER=ollama

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=120

# --- Groq (hosted LLM API) — only used when LLM_PROVIDER=groq ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT=60

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma_store
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Knowledge base ---
KNOWLEDGE_BASE_DIR=./knowledge_base
CHUNK_SIZE=180
CHUNK_OVERLAP=30
TOP_K_CHUNKS=4

# --- Interview behaviour ---
MAX_QUESTIONS=6
ADAPTIVE_DIFFICULTY=true

# --- CORS ---
# Comma-separated list of origins. Include http://localhost:5173 for local frontend development
# and https://pranavkas.github.io for the deployed GitHub Pages frontend.
ALLOWED_ORIGINS=http://localhost:5173,https://pranavkas.github.io
